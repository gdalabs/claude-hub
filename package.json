{
  "name": "claude-hub",
  "version": "1.0.0",
  "description": "A local dashboard for Claude Code — browse sessions, chat, and manage projects from the browser",
  "repository": {
    "type": "git",
    "url": "https://github.com/gdalabs/claude-hub.git"
  },
  "keywords": ["claude", "claude-code", "dashboard", "anthropic", "ai"],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist-server/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@hono/node-server": "^1.13.0",
    "dotenv": "^17.3.1",
    "hono": "^4.12.15"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.1.0",
    "highlight.js": "^11.11.0",
    "marked": "^15.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
